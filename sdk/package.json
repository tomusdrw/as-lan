{
  "name": "@fluffylabs/as-lan",
  "version": "0.0.1",
  "description": "AssemblyScript SDK for building JAM (Join-Accumulate Machine) services",
  "type": "module",
  "ascMain": "index.ts",
  "scripts": {
    "asbuild:test": "asc test/test-run.ts --target test",
    "test": "npm run asbuild:test && node ./bin/test.js",
